# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real IDs.

# Build locale — set to "hu" or "en" at build time
NEXT_PUBLIC_LOCALE=hu

# Canonical site URLs (no trailing slash)
# Netlify (repó netlify.toml): bohemjazz = HU, buhemjazzen = EN
NEXT_PUBLIC_SITE_URL_HU=https://bohemjazz.netlify.app
NEXT_PUBLIC_SITE_URL_EN=https://buhemjazzen.netlify.app

# --- Netlify: két site, ugyanabból a Gitből ---
# bohemjazz.netlify.app (magyar): NEXT_PUBLIC_LOCALE=hu vagy üres
# buhemjazzen.netlify.app (angol): NEXT_PUBLIC_LOCALE=en KÖTELEZŐ
# Részletek: docs/NETLIFY.md
#
# Csak a nyelvváltó gomb URL-jét akarod felülírni (canonical meta marad a fentinél):
# NEXT_PUBLIC_LANGUAGE_SWITCH_URL=https://en-demo--yyy.netlify.app
#
# --- Netlify: „EN” gomb még mindig jazzcapital.hu (újra build nélkül) ---
# Site configuration → Environment variables: NEXT_PUBLIC_SITE_URL_EN = angol deploy URL
# VAGY: Snippet injection (before </body>) a magyar demón:
#   <script>window.__PEER_LOCALE_URL__='https://IDE-MEGY-ANGOL-OLDAL.netlify.app';</script>
# A LocaleSwitchAnchor ezt futásidőben felülírja (új build nem kell).

# --- Analytics (all optional) ---

# Google Tag Manager container ID
# When set, GTM manages GA4 and Ads — leave GA4/Ads vars empty
NEXT_PUBLIC_GTM_ID=

# GA4 Measurement ID (only used if GTM is NOT set)
NEXT_PUBLIC_GA4_ID=

# Google Ads conversion ID (only used if GTM is NOT set)
NEXT_PUBLIC_GADS_ID=
